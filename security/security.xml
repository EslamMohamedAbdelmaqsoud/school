<odoo>
    <!-- Define a new Category (School) for the student model -->
    <record id="student_category" model="ir.module.category">
        <field name="name">School Management</field>
    </record>


    <!-- Define a new Group for the (School Manager) -->
    <record id="school_manager_group" model="res.groups">
        <field name="name">School Manager</field>
        <field name="category_id" ref="school.student_category"/>
        <!--        <field name="implied_ids" eval="[(4, ref('school_user_group'))]"/>-->
    </record>

    <!-- Define a new Group for the (School Teacher) -->
    <record id="school_teacher_group" model="res.groups">
        <field name="name">School Teacher</field>
        <field name="category_id" ref="school.student_category"/>
    </record>

    <!--     Define a new Group for the (School User) -->
    <record id="school_user_group" model="res.groups">
        <field name="name">School User</field>
        <field name="category_id" ref="school.student_category"/>
    </record>

