<odoo>

    <!-- Tree View -->
    <record id="student_tree_view" model="ir.ui.view">
        <field name="name">student tree</field>
        <field name="model">student</field>
        <field name="arch" type="xml">
            <tree class="header_custom">
                <field name="name"/>
                <field name="age"/>
                <field name="grade"/>
                <field name="state"/>
                <field name="course_id"/>
                <field name="ssn_id"/>
                <field name="address" optional="1"/>
                <field name="phone_number" optional="1"/>
                <field name="active" optional="1"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="student_kanban_view" model="ir.ui.view">
        <field name="name">student kanban</field>
        <field name="model">student</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_example" default_group_by="state">
                <field name="name"/>
                <field name="age"/>
                <field name="grade"/>
                <field name="state"/>
                <field name="course_id"/>
                <field name="ssn_id"/>
                <field name="address"/>
                <field name="phone_number"/>
                <field name="active"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click" style="border-left: 3px solid #007bff;">
                            <div class="oe_kanban_content">
                                <div>
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div>
                                    <span>Age:</span>
                                    <field name="age"/>
                                </div>
                                <div>
                                    <span>Grade:</span>
                                    <field name="grade"/>
                                </div>
                                <div>
                                    <span>SSN:</span>
                                    <field name="ssn_id"/>
                                </div>
                                <div>
                                    <span>Course:</span>
                                    <field name="course_id"/>
                                </div>
                                <div class="oe_kanban_footer_left">
                                    <span>
                                        <field name="state" widget="badge" decoration-info="state == 'draft'"
                                               decoration-warning="state == 'pending'"
                                               decoration-success="state == 'sold'"
                                               decoration-danger="state == 'closed'"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="student_calendar_view" model="ir.ui.view">
        <field name="name">student calendar</field>
        <field name="model">student</field>
        <field name="arch" type="xml">
            <calendar string="Student Calendar" date_start="enrollment_date" color="state">
                <field name="name"/>
                <field name="course_id"/>
                <field name="age"/>
                <field name="grade"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="student_pivot_view" model="ir.ui.view">
        <field name="name">student pivot</field>
        <field name="model">student</field>
        <field name="arch" type="xml">
            <pivot string="Student Pivot">
                <field name="course_id" type="row"/>
                <field name="state" type="col"/>
                <field name="grade" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="student_graph_view" model="ir.ui.view">
        <field name="name">student graph</field>
        <field name="model">student</field>
        <field name="arch" type="xml">
            <graph string="Student Graph" type="bar">
                <field name="course_id" type="row"/>
                <field name="grade" type="measure"/>
            </graph>
        </field>
    </record>


    <!-- Form View -->
    <record id="student_form_view" model="ir.ui.view">
        <field name="name">student form</field>
        <field name="model">student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="action_draft" type="object" class="btn-primary" string="Set To Draft"
                                invisible="state == 'draft'"/>
                        <button name="action_pending" type="object" class="btn-secondary" string="Pending"
                                invisible="state != 'draft'"/>
                        <button name="action_sold" type="object" class="btn-success" string="Sold"
                                invisible="state != 'pending'"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <div class="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>
                        <label for="name"/>
                        <h3>
                            <field name="name"/>
                        </h3>
                    </div>
                    <group>

                        <group string="General Info.">
                            <field name="birth_date"/>
                            <field name="age"/>
                            <field name="email"/>
                            <field name="grade"/>
                            <field name="ssn_id"/>
                            <field name="address"/>
                            <field name="phone_number"/>
                            <field name="course_id"/>
                            <field name="class_id"/>
                            <field name="year_id"/>
                            <field name="subject_ids" widget="many2many_tags"/>
                        </group>
                        <group string=" Additional Info.">
                            <field name="image" widget="image" class="oe_avatar" options="{'size': [50, 50]}"/>
                            <field name="enrollment_date"/>
                            <field name="active"/>
                            <field name="gender"/>
                            <field name="language"/>
                            <field name="level"/>
                            <field name="course_final_price"/>
                            <field name="teacher_id"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="student_search_view" model="ir.ui.view">
        <field name="name">student search</field>
        <field name="model">student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="email"/>
                <field name="phone_number"/>

                <filter name="gender" string="Gender Male" domain="[('gender', '=','male')]"/>
                <filter name="gender" string="Gender Female" domain="[('gender', '=', 'female')]"/>

                <filter name="gender" string="Gender" context="{'group_by':'gender'}"/>

            </search>
        </field>
    </record>


    <!-- Window Actions -->
    <record id="student_action" model="ir.actions.act_window">
        <field name="name">student</field>
        <field name="res_model">student</field>
        <field name="view_mode">tree,kanban,calendar,pivot,form,graph</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('student_tree_view')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('student_kanban_view')}),
            (0, 0, {'view_mode': 'calendar', 'view_id': ref('student_calendar_view')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('student_pivot_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('student_form_view')}),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('student_graph_view')})
        ]"/>
        <field name="search_view_id" ref="student_search_view"/>
    </record>

    <!-- Server Actions -->
    <record id="student_closed_server_action" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_student"/>
        <field name="binding_model_id" ref="model_student"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_closed()
        </field>
    </record>

    <!-- Sub Menu Items Of Students -->
    <menuitem id="student_menu_item"
              name="Student"
              parent="students_menu"
              action="student_action"/>

</odoo>

