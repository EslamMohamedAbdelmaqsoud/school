<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View for Student Enrollment Wizard -->
        <record id="view_ex_wizard_form" model="ir.ui.view">
            <field name="name">Student Enrollment Wizard Form</field>
            <field name="model">ex.wizard</field>
            <field name="arch" type="xml">
                <form string="Enroll Student">
                    <sheet>
                        <group>
                            <group>
                                <field name="student_id" placeholder="Select Student" widget="many2one" required="1"/>
                                <field name="course_id" placeholder="Select Course" widget="many2one" required="1"/>
                            </group>
                            <group>
                                <field name="class_id" placeholder="Select Class" widget="many2one" required="1"/>
                                <field name="enrollment_date" required="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes" placeholder="Add any additional notes..." nolabel="1" colspan="2"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_enroll" string="Enroll" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Action to open the wizard -->
        <record id="action_ex_wizard" model="ir.actions.act_window">
            <field name="name">Student Enrollment</field>
            <field name="res_model">ex.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="view_id" ref="view_ex_wizard_form"/>
        </record>

        <!-- Menu Item for the wizard -->
        <menuitem id="menu_student_enrollment_wizard"
                  name="Enroll Student"
                  action="action_ex_wizard"
                  parent="school_management_system_root_menu"
                  sequence="10"/>
    </data>
</odoo>