<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_invoice_document_inherit_product_details" inherit_id="account.report_invoice_document">
            <!-- Add customer details after the header -->
            <xpath expr="//div[@id='informations']" position="before">
                <div class="row mt-4 mb-4">
                    <div class="col-6">
                        <strong>Customer Information:</strong>
                        <table style="width: 100%; margin-top: 10px;">
                            <tr>
                                <td style="padding: 5px;"><strong>Name:</strong></td>
                                <td style="padding: 5px;"><span t-field="o.partner_id.name"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 5px;"><strong>Address:</strong></td>
                                <td style="padding: 5px;">
                                    <span t-field="o.partner_id.street"/><br/>
                                    <span t-field="o.partner_id.city"/>, <span t-field="o.partner_id.state_id.name"/><br/>
                                    <span t-field="o.partner_id.zip"/> <span t-field="o.partner_id.country_id.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 5px;"><strong>Phone:</strong></td>
                                <td style="padding: 5px;"><span t-field="o.partner_id.phone"/></td>
                            </tr>
                            <tr>
                                <td style="padding: 5px;"><strong>Email:</strong></td>
                                <td style="padding: 5px;"><span t-field="o.partner_id.email"/></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </xpath>

            <!-- Add product details columns -->
            <xpath expr="//table[@name='invoice_line_table']/thead/tr/th[@name='th_description']" position="after">
                <th name="th_barcode" class="text-start"><strong>Barcode</strong></th>
                <th name="th_sku" class="text-start"><strong>SKU</strong></th>
                <th name="th_category" class="text-start"><strong>Category</strong></th>
            </xpath>

            <xpath expr="//table[@name='invoice_line_table']/tbody//td[@name='account_invoice_line_name']" position="after">
                <td name="td_barcode" class="text-start"><span t-field="line.product_id.barcode"/></td>
                <td name="td_sku" class="text-start"><span t-field="line.product_id.default_code"/></td>
                <td name="td_category" class="text-start"><span t-field="line.product_id.categ_id.name"/></td>
            </xpath>

            <xpath expr="//table[@name='invoice_line_table']/tbody//td[@name='account_invoice_line_name']" position="after">
                <td name="td_description" class="text-start"><span t-field="line.product_id.description_sale"/></td>
            </xpath>
        </template>
    </data>
</odoo>

