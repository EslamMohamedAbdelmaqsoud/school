<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit the sale order report template to add additional columns for Delivered and Invoiced -->
        <template id="report_salesoeder_document_inherit" inherit_id="sale.report_saleorder_document">
            <!-- Add new columns for Qty Received and Billed in the table header -->
            <xpath expr="//table[@class='table table-sm o_main_table table-borderless mt-4']/thead/tr/th[@name='th_quantity']"
                   position="after">
                <th name="th_qty_delivered" class="text-end">
                    <strong>Delivered</strong>
                </th>
                <th name="th_qty_invoiced" class="text-end">
                    <strong>Invoiced</strong>
                </th>
            </xpath>
            <!-- Add new columns for Qty Received and Billed in the table body -->
            <xpath expr="//table[@class='table table-sm o_main_table table-borderless mt-4']/tbody//td[@class='text-end'][1]"
                   position="after">
                <td class="text-end">
                    <span t-field="line.qty_delivered"/>
                </td>
                <td class="text-end">
                    <span t-field="line.qty_invoiced"/>
                </td>
            </xpath>
        </template>
    </data>
</odoo>
